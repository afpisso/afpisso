{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "afpisso.com" }],
      "destination": "https://byandresfe.com/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/llms.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/markdown; charset=utf-8" },
        { "key": "Vary",         "value": "Accept" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Link",
          "value": "</sitemap.xml>; rel=\"sitemap\", </llms.txt>; rel=\"describedby\"; type=\"text/markdown\""
        },
        { "key": "Vary", "value": "Accept" }
      ]
    }
  ]
}
